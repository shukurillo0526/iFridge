    "steps": [
      {"step_number": 1, "text": "Combine all ingredients except oil in a bowl. Mix gently with hands — do not overwork the meat.", "timer_seconds": null},
      {"step_number": 2, "text": "Divide into 4 equal portions. Shape into patties about 2cm thick. Press a small indent in the center of each.", "timer_seconds": null},
      {"step_number": 3, "text": "Heat oil in a skillet over medium-high heat. Cook patties for 4 minutes per side for medium doneness.", "timer_seconds": 480},
      {"step_number": 4, "text": "Let rest 3 minutes before serving. Serve on buns or with a side salad.", "timer_seconds": 180}
