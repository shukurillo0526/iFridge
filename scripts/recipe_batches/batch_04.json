[
  {
    "title": "Split Pea Soup",
    "ingredients": [
      {"name": "Split peas", "quantity": 1, "unit": "cup", "prep_note": "Rinsed"},
      {"name": "Carrot", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Celery", "quantity": 1, "unit": "stalk", "prep_note": "Diced"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Vegetable broth", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Bay leaf", "quantity": 1, "unit": "leaf", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat oil in a large pot. Sauté onion, carrot, and celery for 5 minutes. Add garlic, cook 30 seconds.", "timer_seconds": 330},
      {"step_number": 2, "text": "Add split peas, broth, and bay leaf. Bring to a boil, then reduce to low. Simmer covered for 45 minutes, stirring occasionally.", "timer_seconds": 2700},
      {"step_number": 3, "text": "Remove bay leaf. Season with salt and pepper. Soup will thicken as it sits.", "timer_seconds": null},
      {"step_number": 4, "text": "Serve hot with crusty bread.", "timer_seconds": null}
    ]
  },
  {
    "title": "Coffee Cake",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Sugar", "quantity": 0.75, "unit": "cup", "prep_note": ""},
      {"name": "Butter", "quantity": 0.5, "unit": "cup", "prep_note": "Softened"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": ""},
      {"name": "Sour cream", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Baking powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Baking soda", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Brown sugar", "quantity": 0.33, "unit": "cup", "prep_note": "For streusel"},
      {"name": "Cinnamon", "quantity": 1, "unit": "tbsp", "prep_note": "For streusel"},
      {"name": "Walnuts", "quantity": 0.5, "unit": "cup", "prep_note": "Chopped, for streusel"}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to 175°C (350°F). Grease a 9-inch square baking pan.", "timer_seconds": null},
      {"step_number": 2, "text": "Mix brown sugar, cinnamon, and walnuts in a bowl for the streusel. Set aside.", "timer_seconds": null},
      {"step_number": 3, "text": "Cream butter and sugar until fluffy. Beat in eggs one at a time, then vanilla.", "timer_seconds": null},
      {"step_number": 4, "text": "Mix flour, baking powder, baking soda. Alternate adding flour mixture and sour cream to the batter.", "timer_seconds": null},
      {"step_number": 5, "text": "Pour half the batter into pan. Sprinkle half the streusel. Add remaining batter, then top with remaining streusel.", "timer_seconds": null},
      {"step_number": 6, "text": "Bake 35-40 minutes until a toothpick comes out clean.", "timer_seconds": 2250},
      {"step_number": 7, "text": "Cool 15 minutes before slicing.", "timer_seconds": 900}
    ]
  },
  {
    "title": "Egg Drop Soup",
    "ingredients": [
      {"name": "Chicken broth", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Eggs", "quantity": 3, "unit": "large", "prep_note": "Beaten"},
      {"name": "Cornstarch", "quantity": 1, "unit": "tbsp", "prep_note": "Mixed with 2 tbsp cold water"},
      {"name": "Soy sauce", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Thinly sliced"},
      {"name": "White pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring broth to a boil in a saucepan. Add soy sauce and salt.", "timer_seconds": 300},
      {"step_number": 2, "text": "Stir in the cornstarch slurry. Cook 1 minute until broth thickens slightly.", "timer_seconds": 60},
      {"step_number": 3, "text": "Reduce to a gentle simmer. Slowly drizzle beaten eggs in a thin stream while stirring the soup in one direction. The eggs will form silky ribbons.", "timer_seconds": 30},
      {"step_number": 4, "text": "Remove from heat immediately. Add sesame oil and white pepper.", "timer_seconds": null},
      {"step_number": 5, "text": "Ladle into bowls and garnish with green onions.", "timer_seconds": null}
    ]
  },
  {
    "title": "Potato Pancakes",
    "ingredients": [
      {"name": "Potatoes", "quantity": 4, "unit": "medium", "prep_note": "Peeled, grated"},
      {"name": "Onion", "quantity": 1, "unit": "small", "prep_note": "Grated"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Flour", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 4, "unit": "tbsp", "prep_note": "For frying"},
      {"name": "Sour cream", "quantity": 4, "unit": "tbsp", "prep_note": "For serving"}
    ],
    "steps": [
      {"step_number": 1, "text": "Squeeze grated potatoes in a clean towel to remove excess moisture. This is critical for crispiness.", "timer_seconds": null},
      {"step_number": 2, "text": "Mix potatoes, onion, egg, flour, salt, and pepper in a bowl.", "timer_seconds": null},
      {"step_number": 3, "text": "Heat oil in a large skillet over medium-high heat. Drop 2 tbsp of mixture per pancake, flatten with a spatula.", "timer_seconds": null},
      {"step_number": 4, "text": "Fry for 3 minutes per side until deep golden and crispy.", "timer_seconds": 360},
      {"step_number": 5, "text": "Drain on paper towels. Serve hot with sour cream.", "timer_seconds": null}
    ]
  },
  {
    "title": "Lentil Dal",
    "ingredients": [
      {"name": "Red lentils", "quantity": 1, "unit": "cup", "prep_note": "Rinsed"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Finely diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "tbsp", "prep_note": "Grated"},
      {"name": "Turmeric", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Cumin seeds", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Garam masala", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Canned diced tomatoes", "quantity": 200, "unit": "g", "prep_note": ""},
      {"name": "Coconut milk", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Water", "quantity": 2.5, "unit": "cups", "prep_note": ""},
      {"name": "Ghee or oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Fresh cilantro", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat ghee in a pot. Add cumin seeds and let them sizzle for 15 seconds.", "timer_seconds": 15},
      {"step_number": 2, "text": "Add onion and cook 4 minutes. Add garlic, ginger, turmeric, and garam masala. Cook 1 minute.", "timer_seconds": 300},
      {"step_number": 3, "text": "Add lentils, tomatoes, and water. Bring to a boil, then simmer uncovered for 20 minutes, stirring occasionally.", "timer_seconds": 1200},
      {"step_number": 4, "text": "Stir in coconut milk and salt. Simmer 5 more minutes until thick and creamy.", "timer_seconds": 300},
      {"step_number": 5, "text": "Garnish with cilantro. Serve with rice or naan bread.", "timer_seconds": null}
    ]
  },
  {
    "title": "Beef Patties",
    "ingredients": [
      {"name": "Ground beef", "quantity": 500, "unit": "g", "prep_note": "80/20 fat ratio"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Finely diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
