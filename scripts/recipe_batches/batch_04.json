  {
    "title": "Honey Butter Carrots",
    "ingredients": [
      {"name": "Carrots", "quantity": 500, "unit": "g", "prep_note": "Peeled, sliced diagonally"},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Honey", "quantity": 2, "unit": "tbsp", "prep_note": ""},
