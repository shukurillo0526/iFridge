      {"name": "Fresh thyme", "quantity": 1, "unit": "tsp", "prep_note": "Leaves only"}
    ],
    "steps": [
      {"step_number": 1, "text": "Boil carrots in salted water for 5 minutes until just tender. Drain well.", "timer_seconds": 300},
      {"step_number": 2, "text": "Melt butter in a skillet over medium heat. Add honey and stir.", "timer_seconds": 60},
      {"step_number": 3, "text": "Add carrots and toss to coat. Cook 3-4 minutes, turning occasionally, until glazed and slightly caramelized.", "timer_seconds": 210},
      {"step_number": 4, "text": "Sprinkle with thyme and salt. Serve as a side dish.", "timer_seconds": null}
    ]
  },
  {
