      {"step_number": 4, "text": "Garnish with green onion and sesame seeds. Serve with rice and lettuce wraps.", "timer_seconds": null}
    ]
  },
  {
    "title": "Stuffed Bell Peppers",
    "ingredients": [
      {"name": "Bell peppers", "quantity": 4, "unit": "large", "prep_note": "Tops cut, seeds removed"},
      {"name": "Ground beef", "quantity": 400, "unit": "g", "prep_note": ""},
