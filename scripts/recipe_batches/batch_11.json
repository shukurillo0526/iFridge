      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to 190C (375F). Cook beef with onion 5 minutes. Add garlic, cook 30 seconds. Drain fat.", "timer_seconds": 330},
      {"step_number": 2, "text": "Mix beef with rice, half the tomato sauce, Italian seasoning, and salt.", "timer_seconds": null},
      {"step_number": 3, "text": "Stuff peppers with the mixture. Place in a baking dish. Pour remaining sauce around the peppers.", "timer_seconds": null},
      {"step_number": 4, "text": "Cover with foil. Bake 30 minutes. Remove foil, top with cheese. Bake 10 more minutes.", "timer_seconds": 2400},
      {"step_number": 5, "text": "Let rest 5 minutes. Serve.", "timer_seconds": 300}
    ]
  },
  {
