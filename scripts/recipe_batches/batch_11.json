      {"step_number": 3, "text": "Squeeze lemon juice over avocado. Season with salt and pepper flakes. Drizzle olive oil.", "timer_seconds": null},
      {"step_number": 4, "text": "Top with a fried or poached egg if desired. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Southern Fried Chicken",
    "ingredients": [
      {"name": "Chicken pieces", "quantity": 1, "unit": "kg", "prep_note": "Drumsticks and thighs"},
      {"name": "Buttermilk", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "All-purpose flour", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Paprika", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Onion powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Cayenne pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 2, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 4, "unit": "cups", "prep_note": "For frying"}
    ],
    "steps": [
      {"step_number": 1, "text": "Soak chicken in buttermilk for at least 1 hour, ideally overnight in the fridge.", "timer_seconds": 3600},
      {"step_number": 2, "text": "Mix flour with paprika, garlic powder, onion powder, cayenne, salt, and pepper.", "timer_seconds": null},
      {"step_number": 3, "text": "Remove chicken from buttermilk, dredge heavily in seasoned flour. Let rest 10 minutes on a rack.", "timer_seconds": 600},
      {"step_number": 4, "text": "Heat oil to 170C (340F). Fry chicken 12-15 minutes, turning once, until golden and internal temp reaches 74C.", "timer_seconds": 810},
      {"step_number": 5, "text": "Drain on a wire rack. Rest 5 minutes before serving.", "timer_seconds": 300}
    ]
  },
  {
