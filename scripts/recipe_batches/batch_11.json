      {"name": "Zucchini", "quantity": 0.5, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Diced"},
      {"name": "Potato", "quantity": 1, "unit": "small", "prep_note": "Cubed"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Korean chili flakes", "quantity": 0.5, "unit": "tsp", "prep_note": "Gochugaru"},
      {"name": "Anchovy broth or water", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Green onion", "quantity": 1, "unit": "stalk", "prep_note": "Chopped"},
      {"name": "Green chili", "quantity": 1, "unit": "small", "prep_note": "Sliced"}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring broth to a boil in a small pot. Dissolve doenjang paste into the broth by pressing through a sieve.", "timer_seconds": 180},
      {"step_number": 2, "text": "Add potato and onion. Simmer 8 minutes until potato is almost tender.", "timer_seconds": 480},
      {"step_number": 3, "text": "Add zucchini, tofu, garlic, and gochugaru. Simmer 5 more minutes.", "timer_seconds": 300},
      {"step_number": 4, "text": "Add green onion and chili. Serve bubbling hot with rice.", "timer_seconds": null}
    ]
  },
  {
    "title": "Plov (Osh)",
    "ingredients": [
      {"name": "Lamb or beef", "quantity": 500, "unit": "g", "prep_note": "Cut into large chunks"},
      {"name": "Rice", "quantity": 2, "unit": "cups", "prep_note": "Devzira or basmati, soaked 30 min"},
      {"name": "Carrots", "quantity": 4, "unit": "large", "prep_note": "Julienned into thick strips"},
      {"name": "Onions", "quantity": 2, "unit": "large", "prep_note": "Sliced into half-rings"},
      {"name": "Vegetable oil", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Cumin seeds", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 1, "unit": "whole head", "prep_note": "Unpeeled, top sliced off"},
      {"name": "Chickpeas", "quantity": 0.5, "unit": "cup", "prep_note": "Soaked overnight, optional"},
      {"name": "Salt", "quantity": 1.5, "unit": "tsp", "prep_note": ""},
      {"name": "Water", "quantity": 3, "unit": "cups", "prep_note": "Boiling"}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat oil in a heavy kazan or Dutch oven over high heat until smoking. Fry onions 5 minutes until deep golden brown.", "timer_seconds": 300},
      {"step_number": 2, "text": "Add meat. Sear on all sides for 5 minutes until browned.", "timer_seconds": 300},
      {"step_number": 3, "text": "Add carrots. Stir-fry 5 minutes without breaking them. Add cumin, salt, and chickpeas.", "timer_seconds": 300},
      {"step_number": 4, "text": "Pour boiling water over. Nestle garlic head in the center. Simmer on medium for 30 minutes (this is the zirvak).", "timer_seconds": 1800},
      {"step_number": 5, "text": "Drain soaked rice. Spread evenly over the zirvak without stirring. Add more boiling water if needed — rice should be just covered.", "timer_seconds": null},
      {"step_number": 6, "text": "Cook uncovered on medium until water absorbs into the rice. Then poke holes with a chopstick, cover tightly, reduce to lowest heat for 25 minutes.", "timer_seconds": 1500},
      {"step_number": 7, "text": "Gently flip the entire plov onto a large serving platter. Serve with achichuk salad.", "timer_seconds": null}
    ]
  }
]
