      {"name": "Sugar", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Asian pear or apple", "quantity": 0.5, "unit": "medium", "prep_note": "Grated"},
      {"name": "Garlic", "quantity": 4, "unit": "cloves", "prep_note": "Minced"},
