      {"step_number": 3, "text": "Spread butter generously over hot corn. Season with salt and pepper.", "timer_seconds": null},
      {"step_number": 4, "text": "Sprinkle parsley if desired. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Chocolate Chip Cookies",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 2.25, "unit": "cups", "prep_note": ""},
      {"name": "Butter", "quantity": 1, "unit": "cup", "prep_note": "Softened"},
      {"name": "Sugar", "quantity": 0.75, "unit": "cup", "prep_note": ""},
      {"name": "Brown sugar", "quantity": 0.75, "unit": "cup", "prep_note": "Packed"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": ""},
      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Baking soda", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Chocolate chips", "quantity": 2, "unit": "cups", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Cream butter with both sugars until fluffy, about 3 minutes. Beat in eggs one at a time, then vanilla.", "timer_seconds": 180},
      {"step_number": 2, "text": "Whisk flour, baking soda, and salt. Add to butter mixture and mix until just combined. Fold in chocolate chips.", "timer_seconds": null},
      {"step_number": 3, "text": "Chill dough 30 minutes for thicker cookies.", "timer_seconds": 1800},
      {"step_number": 4, "text": "Preheat oven to 190C (375F). Scoop rounded tablespoons onto lined baking sheets.", "timer_seconds": null},
      {"step_number": 5, "text": "Bake 9-11 minutes until edges are golden but centers look slightly underdone.", "timer_seconds": 600},
      {"step_number": 6, "text": "Cool on pan 5 minutes, then transfer to a rack.", "timer_seconds": 300}
    ]
  },
  {
    "title": "Doenjang Jjigae",
    "ingredients": [
      {"name": "Doenjang", "quantity": 2, "unit": "tbsp", "prep_note": "Korean fermented soybean paste"},
