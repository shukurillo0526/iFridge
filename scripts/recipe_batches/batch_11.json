[
  {
    "title": "Beef Bulgogi",
    "ingredients": [
      {"name": "Beef sirloin", "quantity": 500, "unit": "g", "prep_note": "Thinly sliced against grain"},
      {"name": "Soy sauce", "quantity": 4, "unit": "tbsp", "prep_note": ""},
