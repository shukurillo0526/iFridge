    ]
  },
  {
    "title": "Chocolate Mug Cake",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 4, "unit": "tbsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Cocoa powder", "quantity": 2, "unit": "tbsp", "prep_note": "Unsweetened"},
      {"name": "Milk", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Egg", "quantity": 1, "unit": "small", "prep_note": ""},
      {"name": "Vanilla", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Baking powder", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Chocolate chips", "quantity": 1, "unit": "tbsp", "prep_note": "Optional"}
    ],
    "steps": [
      {"step_number": 1, "text": "Mix flour, sugar, cocoa, and baking powder in a large microwave-safe mug.", "timer_seconds": null},
      {"step_number": 2, "text": "Add milk, oil, egg, and vanilla. Whisk with a fork until smooth. Stir in chocolate chips.", "timer_seconds": null},
      {"step_number": 3, "text": "Microwave on high for 90 seconds. The cake should be set but still moist in the center.", "timer_seconds": 90},
      {"step_number": 4, "text": "Let cool 1 minute. Eat directly from the mug or turn out onto a plate.", "timer_seconds": 60}
    ]
  },
  {
    "title": "Mushroom Risotto",
    "ingredients": [
      {"name": "Arborio rice", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Mushrooms", "quantity": 300, "unit": "g", "prep_note": "Mixed, sliced"},
      {"name": "Onion", "quantity": 1, "unit": "small", "prep_note": "Finely diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "White wine", "quantity": 0.5, "unit": "cup", "prep_note": "Dry"},
      {"name": "Chicken broth", "quantity": 4, "unit": "cups", "prep_note": "Warm"},
      {"name": "Butter", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Parmesan", "quantity": 0.5, "unit": "cup", "prep_note": "Grated"},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Fresh thyme", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.75, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Sauté mushrooms in 1 tbsp butter and oil over high heat for 5 minutes until golden. Season with thyme. Remove.", "timer_seconds": 300},
      {"step_number": 2, "text": "In the same pot, cook onion in 1 tbsp butter for 3 minutes. Add garlic, 30 seconds. Add rice, stir 1 minute to toast.", "timer_seconds": 270},
      {"step_number": 3, "text": "Pour in wine, stir until absorbed. Then add warm broth one ladle at a time, stirring frequently, waiting until each addition is absorbed. This takes about 18 minutes.", "timer_seconds": 1080},
      {"step_number": 4, "text": "When rice is creamy and al dente, remove from heat. Stir in remaining butter, Parmesan, mushrooms, and salt.", "timer_seconds": null},
      {"step_number": 5, "text": "Cover and rest 2 minutes. Serve immediately.", "timer_seconds": 120}
    ]
  },
  {
    "title": "Chicken Quesadilla",
    "ingredients": [
      {"name": "Flour tortillas", "quantity": 4, "unit": "large", "prep_note": ""},
      {"name": "Cooked chicken", "quantity": 1.5, "unit": "cups", "prep_note": "Shredded"},
      {"name": "Cheddar cheese", "quantity": 1.5, "unit": "cups", "prep_note": "Shredded"},
      {"name": "Bell pepper", "quantity": 0.5, "unit": "medium", "prep_note": "Diced"},
      {"name": "Onion", "quantity": 0.25, "unit": "medium", "prep_note": "Diced"},
      {"name": "Cumin", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Butter", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salsa", "quantity": 4, "unit": "tbsp", "prep_note": "For serving"},
      {"name": "Sour cream", "quantity": 4, "unit": "tbsp", "prep_note": "For serving"}
    ],
    "steps": [
      {"step_number": 1, "text": "Mix chicken with cumin, diced pepper, and onion.", "timer_seconds": null},
      {"step_number": 2, "text": "Place a tortilla in a dry skillet over medium heat. Sprinkle cheese on half, then chicken mixture, then more cheese. Fold in half.", "timer_seconds": null},
      {"step_number": 3, "text": "Cook 2 minutes until bottom is golden and cheese melts. Flip and cook 2 more minutes.", "timer_seconds": 240},
      {"step_number": 4, "text": "Repeat with remaining tortillas. Cut into wedges. Serve with salsa and sour cream.", "timer_seconds": null}
    ]
  },
  {
    "title": "Japchae",
    "ingredients": [
      {"name": "Sweet potato noodles", "quantity": 200, "unit": "g", "prep_note": "Dangmyeon"},
      {"name": "Beef sirloin", "quantity": 150, "unit": "g", "prep_note": "Thinly sliced"},
      {"name": "Spinach", "quantity": 2, "unit": "cups", "prep_note": "Blanched"},
      {"name": "Carrot", "quantity": 1, "unit": "medium", "prep_note": "Julienned"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Mushrooms", "quantity": 4, "unit": "pcs", "prep_note": "Sliced"},
      {"name": "Soy sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Sesame seeds", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 1, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Cook noodles according to package. Drain, rinse, and cut with scissors into shorter lengths. Toss with 1 tbsp soy sauce and 1 tbsp sesame oil.", "timer_seconds": 420},
      {"step_number": 2, "text": "Marinate beef in 1 tbsp soy sauce, sugar, and garlic for 10 minutes. Stir-fry 3 minutes. Remove.", "timer_seconds": 780},
      {"step_number": 3, "text": "Stir-fry carrot 2 minutes, then onion and mushrooms 2 minutes, each separately.", "timer_seconds": 240},
      {"step_number": 4, "text": "Combine noodles, beef, all vegetables, and blanched spinach in a large bowl. Add remaining soy sauce and sesame oil. Toss gently.", "timer_seconds": null},
      {"step_number": 5, "text": "Sprinkle sesame seeds. Serve warm or at room temperature.", "timer_seconds": null}
    ]
  },
  {
    "title": "Classic Waffles",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Milk", "quantity": 1.75, "unit": "cups", "prep_note": ""},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": "Separated"},
      {"name": "Butter", "quantity": 0.33, "unit": "cup", "prep_note": "Melted"},
