      {"name": "Mushrooms", "quantity": 150, "unit": "g", "prep_note": "Halved"},
      {"name": "Lemongrass", "quantity": 2, "unit": "stalks", "prep_note": "Smashed, cut into pieces"},
      {"name": "Galangal or ginger", "quantity": 4, "unit": "slices", "prep_note": ""},
      {"name": "Kaffir lime leaves", "quantity": 4, "unit": "leaves", "prep_note": "Torn"},
      {"name": "Thai chili", "quantity": 3, "unit": "pcs", "prep_note": "Smashed"},
      {"name": "Fish sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Lime juice", "quantity": 3, "unit": "tbsp", "prep_note": "Fresh"},
      {"name": "Sugar", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Water", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Cilantro", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring water to a boil. Add lemongrass, galangal, lime leaves, and chilies. Simmer 5 minutes.", "timer_seconds": 300},
