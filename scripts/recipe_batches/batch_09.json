      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat waffle iron. Whisk flour, sugar, baking powder, and salt.", "timer_seconds": null},
