[
  {
    "title": "Hummus",
    "ingredients": [
      {"name": "Canned chickpeas", "quantity": 1, "unit": "can (400g)", "prep_note": "Drained, reserve liquid"},
      {"name": "Tahini", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Lemon juice", "quantity": 2, "unit": "tbsp", "prep_note": "Fresh"},
      {"name": "Garlic", "quantity": 1, "unit": "clove", "prep_note": ""},
      {"name": "Olive oil", "quantity": 3, "unit": "tbsp", "prep_note": "Extra virgin"},
      {"name": "Cumin", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Paprika", "quantity": 0.25, "unit": "tsp", "prep_note": "For garnish"}
    ],
    "steps": [
      {"step_number": 1, "text": "Blend tahini and lemon juice in a food processor for 1 minute until thick and creamy.", "timer_seconds": 60},
      {"step_number": 2, "text": "Add garlic, cumin, salt, and 1 tbsp olive oil. Blend 30 seconds.", "timer_seconds": 30},
      {"step_number": 3, "text": "Add chickpeas. Blend 1 minute. Scrape sides. Add 2-3 tbsp reserved chickpea liquid. Blend 1 more minute until very smooth.", "timer_seconds": 120},
      {"step_number": 4, "text": "Spread on a plate, drizzle remaining olive oil, sprinkle paprika. Serve with pita.", "timer_seconds": null}
    ]
  },
  {
    "title": "Beef Stroganoff",
    "ingredients": [
      {"name": "Beef sirloin", "quantity": 500, "unit": "g", "prep_note": "Sliced into strips"},
      {"name": "Mushrooms", "quantity": 250, "unit": "g", "prep_note": "Sliced"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Beef broth", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Sour cream", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Dijon mustard", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Flour", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Egg noodles", "quantity": 250, "unit": "g", "prep_note": "Cooked"}
    ],
    "steps": [
      {"step_number": 1, "text": "Season beef with salt and pepper. Sear in hot butter for 2 minutes until browned. Remove.", "timer_seconds": 120},
      {"step_number": 2, "text": "In the same pan, cook mushrooms 4 minutes until golden. Add onion, cook 3 minutes. Add garlic, 30 seconds.", "timer_seconds": 450},
      {"step_number": 3, "text": "Sprinkle flour over vegetables, stir 1 minute. Pour in broth, simmer 5 minutes until thickened.", "timer_seconds": 360},
      {"step_number": 4, "text": "Remove from heat. Stir in sour cream and mustard. Return beef and toss gently.", "timer_seconds": null},
      {"step_number": 5, "text": "Serve over egg noodles. Garnish with fresh parsley.", "timer_seconds": null}
    ]
  },
  {
    "title": "Banana Bread",
    "ingredients": [
      {"name": "Ripe bananas", "quantity": 3, "unit": "large", "prep_note": "Very ripe, mashed"},
      {"name": "All-purpose flour", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Sugar", "quantity": 0.75, "unit": "cup", "prep_note": ""},
      {"name": "Butter", "quantity": 0.33, "unit": "cup", "prep_note": "Melted"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Baking soda", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Walnuts", "quantity": 0.5, "unit": "cup", "prep_note": "Chopped, optional"}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to 175C (350F). Grease a 9x5 loaf pan.", "timer_seconds": null},
      {"step_number": 2, "text": "Mash bananas. Stir in melted butter, sugar, egg, and vanilla.", "timer_seconds": null},
      {"step_number": 3, "text": "Add flour, baking soda, and salt. Fold until just combined. Fold in walnuts if using.", "timer_seconds": null},
      {"step_number": 4, "text": "Pour into pan. Bake 55-60 minutes until a toothpick comes out clean.", "timer_seconds": 3450},
      {"step_number": 5, "text": "Cool in pan 10 minutes, then turn out onto a rack.", "timer_seconds": 600}
    ]
  },
  {
    "title": "Chicken Caesar Salad",
    "ingredients": [
      {"name": "Chicken breast", "quantity": 2, "unit": "large", "prep_note": ""},
      {"name": "Romaine lettuce", "quantity": 1, "unit": "head", "prep_note": "Chopped"},
      {"name": "Parmesan", "quantity": 0.5, "unit": "cup", "prep_note": "Shaved"},
      {"name": "Croutons", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Olive oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Mayonnaise", "quantity": 3, "unit": "tbsp", "prep_note": "For dressing"},
      {"name": "Lemon juice", "quantity": 1, "unit": "tbsp", "prep_note": "For dressing"},
      {"name": "Garlic", "quantity": 1, "unit": "clove", "prep_note": "Minced, for dressing"},
      {"name": "Dijon mustard", "quantity": 1, "unit": "tsp", "prep_note": "For dressing"},
      {"name": "Worcestershire sauce", "quantity": 0.5, "unit": "tsp", "prep_note": "For dressing"},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
