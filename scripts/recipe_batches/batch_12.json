  {
    "title": "Manti",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Water", "quantity": 0.75, "unit": "cup", "prep_note": "Warm"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
