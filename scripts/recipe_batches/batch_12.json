      {"step_number": 4, "text": "Grease a steamer tier. Place manti without touching. Steam over boiling water for 30 minutes.", "timer_seconds": 1800},
      {"step_number": 5, "text": "Mix sour cream with minced garlic. Serve manti with garlic sour cream.", "timer_seconds": null}
    ]
  },
  {
    "title": "Samsa",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Butter or lamb fat", "quantity": 0.5, "unit": "cup", "prep_note": "Cold, cubed"},
