      {"step_number": 2, "text": "Nestle the whole garlic head in the center. Do NOT add water — the vegetables will release enough liquid.", "timer_seconds": null},
      {"step_number": 3, "text": "Cover with a very tight lid. Cook on the lowest heat for 90 minutes. Do not open the lid.", "timer_seconds": 5400},
      {"step_number": 4, "text": "Open carefully. The meat should be falling apart. Garnish with dill. Serve from the pot.", "timer_seconds": null}
    ]
  },
  {
    "title": "Non (Uzbek Flatbread)",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Warm water", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Active dry yeast", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame seeds", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Nigella seeds", "quantity": 1, "unit": "tsp", "prep_note": "Optional"}
    ],
    "steps": [
      {"step_number": 1, "text": "Dissolve yeast and sugar in warm water. Let sit 5 minutes until foamy.", "timer_seconds": 300},
      {"step_number": 2, "text": "Mix flour and salt. Add yeast mixture and oil. Knead 8 minutes. Rest covered for 1 hour.", "timer_seconds": 4080},
      {"step_number": 3, "text": "Preheat oven to 230C (450F) with a baking sheet or stone inside.", "timer_seconds": null},
      {"step_number": 4, "text": "Divide dough into 2 portions. Shape into flat discs 20cm wide. Press the center down with a chekich or fork to create the classic pattern, leaving a raised rim.", "timer_seconds": null},
      {"step_number": 5, "text": "Sprinkle with sesame and nigella seeds. Bake 12-15 minutes until golden.", "timer_seconds": 810},
      {"step_number": 6, "text": "Serve warm alongside any Uzbek meal.", "timer_seconds": null}
    ]
  },
  {
