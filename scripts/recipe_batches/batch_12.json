  {
    "title": "Dimlama",
    "ingredients": [
      {"name": "Lamb or beef", "quantity": 500, "unit": "g", "prep_note": "Large chunks"},
      {"name": "Potato", "quantity": 3, "unit": "large", "prep_note": "Halved"},
