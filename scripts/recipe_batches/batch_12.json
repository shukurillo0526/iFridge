      {"step_number": 3, "text": "Roll dough thin. Cut into 12cm squares. Place filling in center. Fold into triangles, pinch edges tightly.", "timer_seconds": null},
      {"step_number": 4, "text": "Preheat oven to 200C (400F). Place seam-side down on a baking sheet. Brush with egg wash, sprinkle sesame seeds.", "timer_seconds": null},
      {"step_number": 5, "text": "Bake 25 minutes until golden brown and flaky.", "timer_seconds": 1500},
      {"step_number": 6, "text": "Serve hot.", "timer_seconds": null}
    ]
  },
  {
