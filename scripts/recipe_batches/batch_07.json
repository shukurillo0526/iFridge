[
  {
    "title": "American Pancakes",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Buttermilk", "quantity": 1.25, "unit": "cups", "prep_note": ""},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Butter", "quantity": 3, "unit": "tbsp", "prep_note": "Melted"},
      {"name": "Sugar", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Baking powder", "quantity": 1.5, "unit": "tsp", "prep_note": ""},
      {"name": "Baking soda", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Whisk flour, sugar, baking powder, baking soda, and salt in a large bowl.", "timer_seconds": null},
      {"step_number": 2, "text": "In another bowl mix buttermilk, egg, melted butter, and vanilla.", "timer_seconds": null},
      {"step_number": 3, "text": "Pour wet into dry and stir until just combined. Lumps are fine. Rest 5 minutes.", "timer_seconds": 300},
      {"step_number": 4, "text": "Heat a griddle over medium heat, brush with butter. Pour 1/4 cup batter per pancake.", "timer_seconds": null},
      {"step_number": 5, "text": "Cook until bubbles appear and edges set, about 2 minutes. Flip and cook 1 minute more.", "timer_seconds": 180},
      {"step_number": 6, "text": "Stack and serve with maple syrup, butter, and fresh berries.", "timer_seconds": null}
    ]
  },
  {
    "title": "Maeuntang (Korean Spicy Fish Soup)",
    "ingredients": [
      {"name": "White fish fillets", "quantity": 400, "unit": "g", "prep_note": "Cut into chunks"},
      {"name": "Zucchini", "quantity": 1, "unit": "small", "prep_note": "Sliced"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Tofu", "quantity": 200, "unit": "g", "prep_note": "Cubed"},
      {"name": "Korean chili flakes", "quantity": 2, "unit": "tbsp", "prep_note": "Gochugaru"},
      {"name": "Korean chili paste", "quantity": 1, "unit": "tbsp", "prep_note": "Gochujang"},
      {"name": "Garlic", "quantity": 4, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Soy sauce", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Water", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Chopped"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring water to a boil. Add garlic, gochugaru, gochujang, and soy sauce. Stir to dissolve.", "timer_seconds": 300},
      {"step_number": 2, "text": "Add onion and zucchini. Simmer 5 minutes.", "timer_seconds": 300},
      {"step_number": 3, "text": "Add fish and tofu. Cook gently 8 minutes until fish is cooked through.", "timer_seconds": 480},
      {"step_number": 4, "text": "Crack egg into the soup and stir gently. Add green onions and salt.", "timer_seconds": 60},
      {"step_number": 5, "text": "Serve hot with steamed rice.", "timer_seconds": null}
    ]
  },
  {
    "title": "Shoyu Ramen",
    "ingredients": [
      {"name": "Ramen noodles", "quantity": 2, "unit": "portions", "prep_note": "Fresh or dried"},
      {"name": "Chicken broth", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Soy sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Mirin", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "inch", "prep_note": "Sliced"},
      {"name": "Soft-boiled eggs", "quantity": 2, "unit": "large", "prep_note": "Halved"},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"},
      {"name": "Nori sheets", "quantity": 2, "unit": "sheets", "prep_note": "Cut in half"},
      {"name": "Chashu pork or chicken", "quantity": 150, "unit": "g", "prep_note": "Sliced"}
    ],
    "steps": [
      {"step_number": 1, "text": "Simmer broth with garlic, ginger, soy sauce, and mirin for 10 minutes. Strain out ginger.", "timer_seconds": 600},
      {"step_number": 2, "text": "Cook noodles according to package. Drain.", "timer_seconds": 180},
      {"step_number": 3, "text": "Divide noodles between 2 bowls. Ladle hot broth over.", "timer_seconds": null},
      {"step_number": 4, "text": "Top with sliced meat, soft-boiled egg halves, nori, and green onion. Drizzle sesame oil.", "timer_seconds": null}
    ]
  },
  {
    "title": "Margherita Pizza",
    "ingredients": [
      {"name": "Pizza dough", "quantity": 400, "unit": "g", "prep_note": "Store-bought or homemade"},
      {"name": "San Marzano tomatoes", "quantity": 200, "unit": "g", "prep_note": "Crushed by hand"},
      {"name": "Fresh mozzarella", "quantity": 200, "unit": "g", "prep_note": "Sliced or torn"},
      {"name": "Fresh basil", "quantity": 10, "unit": "leaves", "prep_note": ""},
      {"name": "Olive oil", "quantity": 2, "unit": "tbsp", "prep_note": "Extra virgin"},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Flour", "quantity": 2, "unit": "tbsp", "prep_note": "For dusting"}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to maximum (250°C/480°F) with a baking sheet or pizza stone inside for 20 minutes.", "timer_seconds": 1200},
      {"step_number": 2, "text": "Stretch dough on a floured surface into a 30cm round. Transfer to floured peel or parchment.", "timer_seconds": null},
      {"step_number": 3, "text": "Spread crushed tomatoes over dough leaving a 2cm border. Season with salt.", "timer_seconds": null},
      {"step_number": 4, "text": "Distribute mozzarella pieces evenly. Drizzle with 1 tbsp olive oil.", "timer_seconds": null},
      {"step_number": 5, "text": "Slide onto hot baking sheet. Bake 8-10 minutes until crust is golden and cheese is bubbly.", "timer_seconds": 540},
      {"step_number": 6, "text": "Remove. Top with fresh basil and remaining olive oil. Slice and serve.", "timer_seconds": null}
    ]
  },
  {
    "title": "Pad Thai",
    "ingredients": [
      {"name": "Rice noodles", "quantity": 200, "unit": "g", "prep_note": "Soaked in warm water 20 min"},
      {"name": "Shrimp or chicken", "quantity": 200, "unit": "g", "prep_note": "Peeled or sliced"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": ""},
      {"name": "Bean sprouts", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Green onion", "quantity": 3, "unit": "stalks", "prep_note": "Cut into 3cm pieces"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Fish sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Tamarind paste", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Crushed peanuts", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Lime", "quantity": 1, "unit": "medium", "prep_note": "Cut into wedges"}
    ],
    "steps": [
      {"step_number": 1, "text": "Mix fish sauce, tamarind paste, and sugar in a bowl. Set aside as the pad thai sauce.", "timer_seconds": null},
      {"step_number": 2, "text": "Heat oil in a wok over high heat. Cook protein 3 minutes until done. Remove.", "timer_seconds": 180},
      {"step_number": 3, "text": "Add garlic, stir 15 seconds. Push to side, crack eggs and scramble quickly.", "timer_seconds": 30},
      {"step_number": 4, "text": "Add drained noodles and sauce. Toss for 2 minutes until noodles absorb the sauce.", "timer_seconds": 120},
      {"step_number": 5, "text": "Return protein. Add bean sprouts and green onion. Toss 30 seconds.", "timer_seconds": 30},
      {"step_number": 6, "text": "Serve topped with crushed peanuts and lime wedges.", "timer_seconds": null}
    ]
  },
  {
    "title": "Beef Tacos",
    "ingredients": [
      {"name": "Ground beef", "quantity": 400, "unit": "g", "prep_note": ""},
      {"name": "Taco shells", "quantity": 8, "unit": "pcs", "prep_note": "Hard or soft"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Cumin", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Chili powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Paprika", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.75, "unit": "tsp", "prep_note": ""},
      {"name": "Lettuce", "quantity": 1, "unit": "cup", "prep_note": "Shredded"},
      {"name": "Tomato", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Cheddar cheese", "quantity": 0.5, "unit": "cup", "prep_note": "Shredded"},
      {"name": "Sour cream", "quantity": 4, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Cook onion in a skillet over medium heat for 3 minutes. Add garlic, cook 30 seconds.", "timer_seconds": 210},
      {"step_number": 2, "text": "Add ground beef, breaking it up. Cook 6 minutes until browned. Drain excess fat.", "timer_seconds": 360},
      {"step_number": 3, "text": "Add cumin, chili powder, paprika, salt, and 3 tbsp water. Simmer 3 minutes.", "timer_seconds": 180},
      {"step_number": 4, "text": "Warm taco shells according to package directions.", "timer_seconds": 60},
      {"step_number": 5, "text": "Fill shells with seasoned beef. Top with lettuce, tomato, cheese, and sour cream.", "timer_seconds": null}
    ]
  },
  {
    "title": "French Crêpes",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Milk", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": ""},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": "Melted, plus extra for pan"},
      {"name": "Sugar", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "pinch", "prep_note": ""},
      {"name": "Vanilla", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Nutella or jam", "quantity": 4, "unit": "tbsp", "prep_note": "For filling"}
    ],
    "steps": [
      {"step_number": 1, "text": "Blend flour, milk, eggs, melted butter, sugar, salt, and vanilla until smooth. Rest batter 30 minutes in the fridge.", "timer_seconds": 1800},
      {"step_number": 2, "text": "Heat a non-stick pan over medium heat. Brush with butter.", "timer_seconds": 60},
      {"step_number": 3, "text": "Pour 3 tbsp batter, swirl pan to coat thinly. Cook 1 minute until edges lift.", "timer_seconds": 60},
      {"step_number": 4, "text": "Flip with a spatula, cook 30 more seconds.", "timer_seconds": 30},
      {"step_number": 5, "text": "Fill with Nutella, jam, or fresh fruit. Fold into quarters. Dust with powdered sugar.", "timer_seconds": null}
    ]
  },
  {
    "title": "Butter Chicken",
    "ingredients": [
      {"name": "Chicken thighs", "quantity": 600, "unit": "g", "prep_note": "Boneless, cubed"},
      {"name": "Yogurt", "quantity": 0.5, "unit": "cup", "prep_note": "Plain"},
      {"name": "Butter", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Onion", "quantity": 1, "unit": "large", "prep_note": "Finely diced"},
      {"name": "Garlic", "quantity": 4, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "tbsp", "prep_note": "Grated"},
      {"name": "Tomato puree", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Heavy cream", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Garam masala", "quantity": 1.5, "unit": "tsp", "prep_note": ""},
      {"name": "Turmeric", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Chili powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Marinate chicken in yogurt, turmeric, chili powder, and salt for 15 minutes.", "timer_seconds": 900},
      {"step_number": 2, "text": "Melt butter in a large pan. Sear chicken 3 minutes per side. Remove.", "timer_seconds": 360},
      {"step_number": 3, "text": "In the same pan, sauté onion 5 minutes. Add garlic, ginger, cook 1 minute.", "timer_seconds": 360},
      {"step_number": 4, "text": "Add tomato puree, garam masala, and sugar. Simmer 10 minutes until sauce thickens.", "timer_seconds": 600},
      {"step_number": 5, "text": "Return chicken, add cream. Simmer 10 minutes until chicken is cooked through and sauce is rich.", "timer_seconds": 600},
      {"step_number": 6, "text": "Serve with basmati rice or naan bread.", "timer_seconds": null}
    ]
  },
  {
    "title": "Spanish Tortilla",
    "ingredients": [
      {"name": "Potatoes", "quantity": 3, "unit": "medium", "prep_note": "Peeled, thinly sliced"},
      {"name": "Eggs", "quantity": 6, "unit": "large", "prep_note": ""},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Thinly sliced"},
      {"name": "Olive oil", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat oil in a 10-inch non-stick skillet over medium heat. Add potatoes and onion. Cook gently for 15 minutes, stirring occasionally, until tender but not browned.", "timer_seconds": 900},
      {"step_number": 2, "text": "Drain potatoes, reserving 2 tbsp oil. Beat eggs with salt in a large bowl. Fold in potatoes.", "timer_seconds": null},
      {"step_number": 3, "text": "Heat reserved oil in the skillet over medium heat. Pour egg-potato mixture in. Cook 5 minutes until edges set.", "timer_seconds": 300},
      {"step_number": 4, "text": "Place a plate over the pan, flip the tortilla onto it, then slide back in to cook the other side 3 minutes.", "timer_seconds": 180},
      {"step_number": 5, "text": "Slide onto a plate. Let rest 5 minutes. Serve warm or at room temperature, cut into wedges.", "timer_seconds": 300}
    ]
  },
  {
    "title": "Greek Moussaka",
    "ingredients": [
      {"name": "Eggplant", "quantity": 2, "unit": "large", "prep_note": "Sliced 1cm thick"},
      {"name": "Ground lamb or beef", "quantity": 500, "unit": "g", "prep_note": ""},
      {"name": "Onion", "quantity": 1, "unit": "large", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Canned crushed tomatoes", "quantity": 400, "unit": "g", "prep_note": ""},
      {"name": "Cinnamon", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Butter", "quantity": 3, "unit": "tbsp", "prep_note": "For bechamel"},
      {"name": "Flour", "quantity": 3, "unit": "tbsp", "prep_note": "For bechamel"},
      {"name": "Milk", "quantity": 2, "unit": "cups", "prep_note": "Warm, for bechamel"},
      {"name": "Egg yolk", "quantity": 1, "unit": "large", "prep_note": "For bechamel"},
      {"name": "Nutmeg", "quantity": 1, "unit": "pinch", "prep_note": ""},
      {"name": "Olive oil", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Salt eggplant slices and let sit 20 minutes. Pat dry. Brush with oil and broil 4 minutes per side until golden.", "timer_seconds": 1680},
      {"step_number": 2, "text": "Brown meat with onion for 6 minutes. Add garlic, tomatoes, cinnamon, salt. Simmer 15 minutes.", "timer_seconds": 1260},
      {"step_number": 3, "text": "Make bechamel: melt butter, whisk in flour for 1 minute, gradually add warm milk whisking constantly. Cook 5 minutes until thick. Remove from heat, stir in egg yolk and nutmeg.", "timer_seconds": 360},
      {"step_number": 4, "text": "Preheat oven to 180°C (350°F). Layer eggplant, then meat sauce, then eggplant in a baking dish. Pour bechamel on top.", "timer_seconds": null},
      {"step_number": 5, "text": "Bake 40 minutes until golden and bubbly.", "timer_seconds": 2400},
      {"step_number": 6, "text": "Rest 15 minutes before cutting. Serve warm.", "timer_seconds": 900}
    ]
  }
]
