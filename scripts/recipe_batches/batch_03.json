[
  {
    "title": "Soy-Glazed Chicken Bites",
    "ingredients": [
      {"name": "Chicken thighs", "quantity": 500, "unit": "g", "prep_note": "Boneless, cut into bite-size pieces"},
      {"name": "Soy sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Honey", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "tsp", "prep_note": "Grated"},
      {"name": "Cornstarch", "quantity": 2, "unit": "tbsp", "prep_note": "For coating"},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame seeds", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"}
    ],
    "steps": [
      {"step_number": 1, "text": "Toss chicken pieces in cornstarch until evenly coated. Shake off excess.", "timer_seconds": null},
      {"step_number": 2, "text": "Heat oil in a large skillet over medium-high heat. Fry chicken pieces for 6 minutes, turning halfway, until golden and crispy.", "timer_seconds": 360},
      {"step_number": 3, "text": "Mix soy sauce, honey, garlic, and ginger in a small bowl.", "timer_seconds": null},
      {"step_number": 4, "text": "Pour sauce into the skillet. Toss chicken to coat evenly. Cook for 2 minutes until sauce is glossy and sticky.", "timer_seconds": 120},
      {"step_number": 5, "text": "Garnish with sesame seeds and green onions. Serve over rice.", "timer_seconds": null}
    ]
  },
  {
    "title": "Egg Fried Bread",
    "ingredients": [
      {"name": "Bread", "quantity": 4, "unit": "slices", "prep_note": "Thick-cut white or sourdough"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": "Beaten"},
      {"name": "Milk", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Cinnamon", "quantity": 0.5, "unit": "tsp", "prep_note": "Optional"},
      {"name": "Salt", "quantity": 1, "unit": "pinch", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Whisk eggs, milk, cinnamon, and salt together in a shallow dish.", "timer_seconds": null},
      {"step_number": 2, "text": "Melt butter in a non-stick pan over medium heat.", "timer_seconds": 60},
      {"step_number": 3, "text": "Dip each bread slice into the egg mixture, coating both sides. Let excess drip off.", "timer_seconds": null},
      {"step_number": 4, "text": "Fry for 2 minutes per side until golden brown and crispy.", "timer_seconds": 240},
      {"step_number": 5, "text": "Serve immediately with honey, jam, or fresh fruit.", "timer_seconds": null}
    ]
  },
  {
    "title": "One-Pot Chicken Rice",
    "ingredients": [
      {"name": "Chicken thighs", "quantity": 4, "unit": "pcs", "prep_note": "Bone-in, skin-on"},
      {"name": "Rice", "quantity": 1.5, "unit": "cups", "prep_note": "Rinsed"},
      {"name": "Chicken broth", "quantity": 2.5, "unit": "cups", "prep_note": ""},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Paprika", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Turmeric", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Fresh parsley", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Season chicken with salt, pepper, and paprika. Heat oil in a large pot over medium-high heat.", "timer_seconds": null},
      {"step_number": 2, "text": "Sear chicken skin-side down for 4 minutes until skin is golden. Flip and sear 2 more minutes. Remove.", "timer_seconds": 360},
      {"step_number": 3, "text": "In the same pot, sauté onion for 3 minutes. Add garlic and turmeric, cook 30 seconds.", "timer_seconds": 210},
      {"step_number": 4, "text": "Add rinsed rice, stir to coat in the oil for 1 minute. Pour in broth and bring to a boil.", "timer_seconds": 120},
      {"step_number": 5, "text": "Nestle chicken pieces on top of the rice. Reduce heat to low, cover tightly. Cook for 20 minutes without lifting the lid.", "timer_seconds": 1200},
      {"step_number": 6, "text": "Remove from heat and let rest covered for 5 minutes. Fluff rice with a fork, sprinkle parsley, and serve.", "timer_seconds": 300}
    ]
  },
  {
    "title": "Creamy Mashed Potatoes",
    "ingredients": [
      {"name": "Potatoes", "quantity": 1, "unit": "kg", "prep_note": "Peeled, quartered"},
      {"name": "Butter", "quantity": 4, "unit": "tbsp", "prep_note": ""},
      {"name": "Heavy cream", "quantity": 0.5, "unit": "cup", "prep_note": "Warm"},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": "Plus extra for boiling water"},
      {"name": "White pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Chives", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Place potatoes in a large pot, cover with cold water. Add 1 tbsp salt. Bring to a boil over high heat.", "timer_seconds": 600},
      {"step_number": 2, "text": "Reduce heat to medium. Simmer for 15-18 minutes until potatoes are fork-tender.", "timer_seconds": 990},
      {"step_number": 3, "text": "Drain well and return to the pot. Let steam dry for 1 minute over low heat.", "timer_seconds": 60},
      {"step_number": 4, "text": "Add butter and mash with a potato masher. Add warm cream gradually, mashing until smooth and creamy.", "timer_seconds": null},
      {"step_number": 5, "text": "Season with salt and white pepper. Top with chives. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Soy Garlic Chicken",
    "ingredients": [
      {"name": "Chicken wings or drumettes", "quantity": 700, "unit": "g", "prep_note": ""},
      {"name": "Soy sauce", "quantity": 4, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 8, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Brown sugar", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Rice vinegar", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Cornstarch", "quantity": 3, "unit": "tbsp", "prep_note": "For coating"},
      {"name": "Vegetable oil", "quantity": 3, "unit": "tbsp", "prep_note": "For frying"},
      {"name": "Sesame seeds", "quantity": 1, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Pat chicken dry with paper towels. Toss in cornstarch until well coated.", "timer_seconds": null},
      {"step_number": 2, "text": "Heat oil in a large pan over medium-high heat. Fry chicken for 10-12 minutes, turning occasionally, until golden and cooked through.", "timer_seconds": 660},
      {"step_number": 3, "text": "While chicken fries, mix soy sauce, garlic, brown sugar, rice vinegar, and sesame oil in a bowl.", "timer_seconds": null},
      {"step_number": 4, "text": "Drain excess oil from the pan. Pour sauce over chicken. Cook for 2-3 minutes, tossing constantly, until sauce is thick and sticky.", "timer_seconds": 150},
      {"step_number": 5, "text": "Sprinkle with sesame seeds. Serve hot.", "timer_seconds": null}
    ]
  },
  {
    "title": "Carrot Ginger Soup",
    "ingredients": [
      {"name": "Carrots", "quantity": 500, "unit": "g", "prep_note": "Peeled, chopped"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Ginger", "quantity": 2, "unit": "tbsp", "prep_note": "Fresh, grated"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Vegetable broth", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Coconut milk", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Cumin", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Lime juice", "quantity": 1, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat olive oil in a pot over medium heat. Sauté onion for 4 minutes. Add garlic, ginger, and cumin. Cook 1 minute.", "timer_seconds": 300},
      {"step_number": 2, "text": "Add carrots and broth. Bring to a boil, then reduce and simmer for 20 minutes until carrots are very soft.", "timer_seconds": 1200},
      {"step_number": 3, "text": "Blend until completely smooth using an immersion blender or regular blender.", "timer_seconds": null},
      {"step_number": 4, "text": "Stir in coconut milk, salt, and lime juice. Heat through for 2 minutes.", "timer_seconds": 120},
      {"step_number": 5, "text": "Serve with a swirl of coconut milk and crusty bread.", "timer_seconds": null}
    ]
  },
  {
    "title": "Pasta with Tomato Sauce",
    "ingredients": [
      {"name": "Spaghetti", "quantity": 300, "unit": "g", "prep_note": ""},
      {"name": "Canned crushed tomatoes", "quantity": 400, "unit": "g", "prep_note": ""},
      {"name": "Garlic", "quantity": 4, "unit": "cloves", "prep_note": "Thinly sliced"},
      {"name": "Olive oil", "quantity": 3, "unit": "tbsp", "prep_note": "Extra virgin"},
      {"name": "Fresh basil", "quantity": 8, "unit": "leaves", "prep_note": ""},
      {"name": "Sugar", "quantity": 0.5, "unit": "tsp", "prep_note": "To balance acidity"},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": "Plus extra for pasta water"},
      {"name": "Red pepper flakes", "quantity": 0.25, "unit": "tsp", "prep_note": "Optional"},
      {"name": "Parmesan", "quantity": 0.25, "unit": "cup", "prep_note": "Grated"}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring a large pot of salted water to a rolling boil. Cook spaghetti according to package directions minus 1 minute (al dente). Reserve 1 cup pasta water before draining.", "timer_seconds": 540},
      {"step_number": 2, "text": "Meanwhile, heat olive oil in a large pan over medium-low heat. Add garlic slices and red pepper flakes. Cook gently for 2 minutes until garlic is light gold — not brown.", "timer_seconds": 120},
      {"step_number": 3, "text": "Add crushed tomatoes, sugar, and salt. Simmer for 15 minutes, stirring occasionally.", "timer_seconds": 900},
      {"step_number": 4, "text": "Add drained pasta to the sauce with 0.25 cup pasta water. Toss over medium heat for 1 minute until sauce clings to pasta.", "timer_seconds": 60},
      {"step_number": 5, "text": "Remove from heat. Tear basil over the top, sprinkle Parmesan, and serve.", "timer_seconds": null}
    ]
  },
  {
    "title": "Veggie Omelette",
    "ingredients": [
      {"name": "Eggs", "quantity": 3, "unit": "large", "prep_note": ""},
      {"name": "Bell pepper", "quantity": 0.5, "unit": "medium", "prep_note": "Diced"},
      {"name": "Mushrooms", "quantity": 3, "unit": "pcs", "prep_note": "Sliced"},
      {"name": "Onion", "quantity": 0.25, "unit": "medium", "prep_note": "Diced"},
      {"name": "Baby spinach", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Cheddar cheese", "quantity": 0.25, "unit": "cup", "prep_note": "Shredded"},
      {"name": "Butter", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 1, "unit": "pinch", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Melt half the butter in a non-stick pan over medium heat. Sauté onion, bell pepper, and mushrooms for 3 minutes until softened. Add spinach, stir until wilted. Remove and set aside.", "timer_seconds": 210},
      {"step_number": 2, "text": "Whisk eggs with salt and pepper until frothy.", "timer_seconds": null},
      {"step_number": 3, "text": "Add remaining butter to the same pan over medium-low heat. Pour in eggs and swirl to cover the pan evenly.", "timer_seconds": null},
      {"step_number": 4, "text": "Cook undisturbed for 2 minutes. Gently lift edges with a spatula, tilting pan to let uncooked egg flow underneath.", "timer_seconds": 120},
      {"step_number": 5, "text": "When the top is almost set, spread sautéed vegetables and cheese on one half. Fold the other half over. Cook 30 more seconds.", "timer_seconds": 30},
      {"step_number": 6, "text": "Slide onto a plate and serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Beef Fried Rice",
    "ingredients": [
      {"name": "Beef sirloin", "quantity": 250, "unit": "g", "prep_note": "Thinly sliced against the grain"},
      {"name": "Cooked rice", "quantity": 3, "unit": "cups", "prep_note": "Day-old, cold"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": "Beaten"},
      {"name": "Soy sauce", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Oyster sauce", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Frozen peas", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat 1 tbsp oil in a wok over high heat. Sear beef slices for 2 minutes until browned. Remove and set aside.", "timer_seconds": 120},
      {"step_number": 2, "text": "Add remaining oil. Scramble eggs quickly, about 30 seconds. Remove.", "timer_seconds": 30},
      {"step_number": 3, "text": "Stir-fry garlic for 15 seconds. Add peas and cook 1 minute.", "timer_seconds": 75},
      {"step_number": 4, "text": "Add cold rice. Press and stir-fry for 3-4 minutes until rice is heated through and slightly charred.", "timer_seconds": 240},
      {"step_number": 5, "text": "Return beef and eggs. Add soy sauce, oyster sauce, and sesame oil. Toss everything for 1 minute.", "timer_seconds": 60},
      {"step_number": 6, "text": "Garnish with green onions and serve.", "timer_seconds": null}
    ]
  },
  {
    "title": "Butter Bean Stew",
    "ingredients": [
      {"name": "Butter beans (lima beans)", "quantity": 2, "unit": "cans (400g each)", "prep_note": "Drained"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Canned diced tomatoes", "quantity": 400, "unit": "g", "prep_note": ""},
      {"name": "Vegetable broth", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Smoked paprika", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Cumin", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Olive oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Baby spinach", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Lemon juice", "quantity": 1, "unit": "tbsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat olive oil in a large pot over medium heat. Sauté onion for 4 minutes until translucent.", "timer_seconds": 240},
      {"step_number": 2, "text": "Add garlic, paprika, and cumin. Cook 1 minute until fragrant.", "timer_seconds": 60},
      {"step_number": 3, "text": "Add diced tomatoes, broth, and beans. Bring to a simmer. Cook for 15 minutes, stirring occasionally.", "timer_seconds": 900},
      {"step_number": 4, "text": "Stir in spinach and cook until wilted, about 2 minutes. Add salt and lemon juice.", "timer_seconds": 120},
      {"step_number": 5, "text": "Serve in bowls with crusty bread or over couscous.", "timer_seconds": null}
    ]
  }
]
