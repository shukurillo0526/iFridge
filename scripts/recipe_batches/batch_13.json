      {"step_number": 2, "text": "Add remaining oil. Stir-fry tomatoes for 3 minutes until they soften and release juice.", "timer_seconds": 180},
      {"step_number": 3, "text": "Add sugar, salt, and ketchup. Stir 30 seconds.", "timer_seconds": 30},
      {"step_number": 4, "text": "Return eggs. Toss gently for 30 seconds. Garnish with green onion. Serve over rice.", "timer_seconds": 30}
    ]
  },
  {
    "title": "Chicken Broccoli Bake",
    "ingredients": [
      {"name": "Chicken breast", "quantity": 400, "unit": "g", "prep_note": "Cubed"},
      {"name": "Broccoli", "quantity": 3, "unit": "cups", "prep_note": "Florets"},
