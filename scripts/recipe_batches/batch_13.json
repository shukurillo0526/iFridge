      {"step_number": 4, "text": "Garnish with sesame seeds and green onion. Serve as a side.", "timer_seconds": null}
    ]
  },
  {
    "title": "Tomato Egg Stir-Fry",
    "ingredients": [
      {"name": "Tomatoes", "quantity": 3, "unit": "medium", "prep_note": "Cut into wedges"},
      {"name": "Eggs", "quantity": 4, "unit": "large", "prep_note": "Beaten"},
      {"name": "Sugar", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
