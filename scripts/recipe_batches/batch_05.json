[
  {
    "title": "Creamy Chicken Pasta",
    "ingredients": [
      {"name": "Penne pasta", "quantity": 300, "unit": "g", "prep_note": ""},
      {"name": "Chicken breast", "quantity": 350, "unit": "g", "prep_note": "Sliced thin"},
      {"name": "Heavy cream", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Parmesan", "quantity": 0.5, "unit": "cup", "prep_note": "Grated"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Italian seasoning", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Fresh basil", "quantity": 6, "unit": "leaves", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Cook pasta in salted boiling water until al dente. Reserve 0.5 cup pasta water, then drain.", "timer_seconds": 540},
      {"step_number": 2, "text": "Heat oil in a large skillet over medium-high heat. Season chicken with salt, pepper, and Italian seasoning. Sear 3 minutes per side. Remove and slice.", "timer_seconds": 360},
      {"step_number": 3, "text": "In the same pan, sauté garlic for 30 seconds. Pour in cream and bring to a gentle simmer for 3 minutes.", "timer_seconds": 210},
      {"step_number": 4, "text": "Stir in Parmesan until melted. Add pasta and chicken. Toss with pasta water if needed to loosen.", "timer_seconds": 60},
      {"step_number": 5, "text": "Top with fresh basil and serve.", "timer_seconds": null}
    ]
  },
  {
    "title": "Egg Curry",
    "ingredients": [
      {"name": "Eggs", "quantity": 6, "unit": "large", "prep_note": "Hard-boiled, peeled"},
      {"name": "Onion", "quantity": 1, "unit": "large", "prep_note": "Finely diced"},
      {"name": "Tomatoes", "quantity": 2, "unit": "medium", "prep_note": "Pureed"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "tbsp", "prep_note": "Grated"},
      {"name": "Turmeric", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Cumin", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Coriander powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Chili powder", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Fresh cilantro", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat oil in a pan. Sauté onion for 5 minutes until golden. Add garlic and ginger, cook 1 minute.", "timer_seconds": 360},
      {"step_number": 2, "text": "Add turmeric, cumin, coriander, and chili powder. Stir for 30 seconds.", "timer_seconds": 30},
      {"step_number": 3, "text": "Pour in tomato puree and salt. Simmer 10 minutes until sauce thickens.", "timer_seconds": 600},
      {"step_number": 4, "text": "Score the boiled eggs with shallow cuts. Add to the sauce. Simmer 5 minutes, spooning sauce over eggs.", "timer_seconds": 300},
      {"step_number": 5, "text": "Garnish with cilantro. Serve with rice or naan.", "timer_seconds": null}
    ]
  },
  {
    "title": "Crispy Fried Potatoes",
    "ingredients": [
      {"name": "Potatoes", "quantity": 4, "unit": "medium", "prep_note": "Cubed 2cm"},
      {"name": "Vegetable oil", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic powder", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Paprika", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Fresh parsley", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Parboil potato cubes in salted water for 5 minutes. Drain and let steam dry.", "timer_seconds": 300},
      {"step_number": 2, "text": "Heat oil in a large skillet over medium-high heat.", "timer_seconds": 60},
      {"step_number": 3, "text": "Add potatoes in a single layer. Cook without moving for 4 minutes until a golden crust forms. Flip and repeat.", "timer_seconds": 480},
      {"step_number": 4, "text": "Season with garlic powder, paprika, salt, and pepper. Toss for 1 minute.", "timer_seconds": 60},
      {"step_number": 5, "text": "Sprinkle with parsley and serve hot.", "timer_seconds": null}
    ]
  },
  {
    "title": "Bean and Onion Salad",
    "ingredients": [
      {"name": "Canned white beans", "quantity": 1, "unit": "can (400g)", "prep_note": "Drained, rinsed"},
      {"name": "Red onion", "quantity": 0.5, "unit": "medium", "prep_note": "Thinly sliced"},
      {"name": "Cherry tomatoes", "quantity": 1, "unit": "cup", "prep_note": "Halved"},
      {"name": "Fresh parsley", "quantity": 3, "unit": "tbsp", "prep_note": "Chopped"},
      {"name": "Olive oil", "quantity": 3, "unit": "tbsp", "prep_note": "Extra virgin"},
      {"name": "Red wine vinegar", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Whisk olive oil, vinegar, salt, and pepper in a large bowl.", "timer_seconds": null},
      {"step_number": 2, "text": "Add beans, onion, tomatoes, and parsley. Toss gently to combine.", "timer_seconds": null},
      {"step_number": 3, "text": "Let sit at room temperature for 10 minutes for flavors to meld.", "timer_seconds": 600},
      {"step_number": 4, "text": "Serve as a side dish or light lunch.", "timer_seconds": null}
    ]
  },
  {
    "title": "Milk Bread Rolls",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Whole milk", "quantity": 0.75, "unit": "cup", "prep_note": "Warm"},
      {"name": "Butter", "quantity": 3, "unit": "tbsp", "prep_note": "Melted"},
      {"name": "Sugar", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Active dry yeast", "quantity": 2.25, "unit": "tsp", "prep_note": "1 packet"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Dissolve yeast and 1 tsp sugar in warm milk. Let sit 5 minutes until foamy.", "timer_seconds": 300},
      {"step_number": 2, "text": "Mix flour, remaining sugar, and salt. Add yeast mixture, egg, and melted butter. Knead 8 minutes until smooth and elastic.", "timer_seconds": 480},
      {"step_number": 3, "text": "Place in a greased bowl, cover with a towel. Let rise 1 hour until doubled.", "timer_seconds": 3600},
      {"step_number": 4, "text": "Punch down dough. Divide into 9 equal pieces. Shape into balls and place in a greased 9-inch square pan.", "timer_seconds": null},
      {"step_number": 5, "text": "Cover and let rise 30 minutes.", "timer_seconds": 1800},
      {"step_number": 6, "text": "Preheat oven to 175°C (350°F). Brush tops with a little milk. Bake 22-25 minutes until golden.", "timer_seconds": 1410},
      {"step_number": 7, "text": "Brush with melted butter while warm. Serve.", "timer_seconds": null}
    ]
  },
  {
    "title": "Chicken Fried Rice",
    "ingredients": [
      {"name": "Cooked rice", "quantity": 3, "unit": "cups", "prep_note": "Day-old, cold"},
      {"name": "Chicken breast", "quantity": 200, "unit": "g", "prep_note": "Diced small"},
