      {"step_number": 3, "text": "Drizzle soy sauce and toss for 1 minute.", "timer_seconds": 60},
      {"step_number": 4, "text": "Top with sesame seeds and green onion. Serve as a quick side.", "timer_seconds": null}
    ]
  },
  {
