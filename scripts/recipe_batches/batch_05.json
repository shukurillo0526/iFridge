      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat 1 tbsp oil in a wok over high heat. Cook diced chicken for 4 minutes until golden. Remove.", "timer_seconds": 240},
      {"step_number": 2, "text": "Scramble eggs quickly in the wok, about 30 seconds. Remove.", "timer_seconds": 30},
      {"step_number": 3, "text": "Add remaining oil. Stir-fry garlic 15 seconds, then add frozen vegetables for 2 minutes.", "timer_seconds": 135},
      {"step_number": 4, "text": "Add cold rice, pressing against the wok. Stir-fry 3 minutes until heated and slightly crispy.", "timer_seconds": 180},
      {"step_number": 5, "text": "Return chicken and eggs. Add soy sauce and sesame oil. Toss 1 minute. Garnish with green onion.", "timer_seconds": 60}
    ]
  },
  {
    "title": "Potato Carrot Gratin",
    "ingredients": [
      {"name": "Potatoes", "quantity": 3, "unit": "large", "prep_note": "Thinly sliced"},
