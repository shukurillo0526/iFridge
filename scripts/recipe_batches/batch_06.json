      {"name": "Salsa", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Avocado", "quantity": 0.5, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Scramble eggs in a buttered pan over medium heat until just set, about 2 minutes. Season with salt.", "timer_seconds": 120},
      {"step_number": 2, "text": "Warm tortillas in a dry pan for 15 seconds per side.", "timer_seconds": 30},
      {"step_number": 3, "text": "Layer scrambled eggs, beans, cheese, avocado, and salsa down the center of each tortilla.", "timer_seconds": null},
      {"step_number": 4, "text": "Fold the bottom up, then roll tightly from one side. Slice in half and serve.", "timer_seconds": null}
    ]
  },
  {
