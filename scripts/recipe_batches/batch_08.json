  {
    "title": "Falafel",
    "ingredients": [
      {"name": "Dried chickpeas", "quantity": 1, "unit": "cup", "prep_note": "Soaked overnight — do NOT use canned"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Rough chopped"},
      {"name": "Fresh parsley", "quantity": 0.5, "unit": "cup", "prep_note": "Packed"},
      {"name": "Fresh cilantro", "quantity": 0.25, "unit": "cup", "prep_note": ""},
      {"name": "Garlic", "quantity": 4, "unit": "cloves", "prep_note": ""},
      {"name": "Cumin", "quantity": 1.5, "unit": "tsp", "prep_note": ""},
      {"name": "Coriander", "quantity": 1, "unit": "tsp", "prep_note": "Ground"},
      {"name": "Baking powder", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 3, "unit": "cups", "prep_note": "For frying"}
    ],
    "steps": [
      {"step_number": 1, "text": "Drain soaked chickpeas. Pulse in a food processor with onion, herbs, garlic, and spices until a coarse, cohesive mixture forms. Do not puree.", "timer_seconds": null},
      {"step_number": 2, "text": "Mix in baking powder. Refrigerate mixture 30 minutes.", "timer_seconds": 1800},
      {"step_number": 3, "text": "Shape into 12 patties or balls, about 3cm wide.", "timer_seconds": null},
      {"step_number": 4, "text": "Heat oil to 175°C (350°F). Fry falafel in batches for 3-4 minutes until deep golden brown.", "timer_seconds": 210},
      {"step_number": 5, "text": "Drain on paper towels. Serve in pita with tahini, pickles, and vegetables.", "timer_seconds": null}
    ]
  },
  {
    "title": "Chicken Teriyaki",
    "ingredients": [
      {"name": "Chicken thighs", "quantity": 500, "unit": "g", "prep_note": "Boneless, skin-on"},
      {"name": "Soy sauce", "quantity": 4, "unit": "tbsp", "prep_note": ""},
      {"name": "Mirin", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Sake or rice wine", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sugar", "quantity": 1.5, "unit": "tbsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Cooked rice", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Sesame seeds", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"}
