      {"step_number": 3, "text": "Flip and cook 4 minutes on the other side.", "timer_seconds": 240},
      {"step_number": 4, "text": "Pour teriyaki sauce over chicken. Simmer 3 minutes, basting frequently, until sauce is thick and glossy.", "timer_seconds": 180},
      {"step_number": 5, "text": "Slice chicken. Serve over rice, drizzle remaining sauce, and top with green onion and sesame seeds.", "timer_seconds": null}
