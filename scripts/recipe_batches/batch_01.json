[
  {
    "title": "Dumpling Soup",
    "ingredients": [
      {"name": "Frozen dumplings", "quantity": 20, "unit": "pcs", "prep_note": "Any filling"},
      {"name": "Chicken broth", "quantity": 4, "unit": "cups", "prep_note": "Low sodium"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "inch", "prep_note": "Thinly sliced"},
      {"name": "Soy sauce", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"},
      {"name": "Baby spinach", "quantity": 1, "unit": "cup", "prep_note": "Washed"},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": "To taste"},
      {"name": "White pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Bring the chicken broth to a boil in a large pot over high heat.", "timer_seconds": 300},
      {"step_number": 2, "text": "Add minced garlic and sliced ginger. Reduce heat to medium and let simmer for 3 minutes to infuse flavors.", "timer_seconds": 180},
      {"step_number": 3, "text": "Gently add the frozen dumplings one by one so they don't stick. Stir carefully.", "timer_seconds": null},
      {"step_number": 4, "text": "Cook dumplings for 6-8 minutes until they float to the surface and are cooked through.", "timer_seconds": 480},
      {"step_number": 5, "text": "Add soy sauce, sesame oil, and baby spinach. Stir until spinach is wilted, about 1 minute.", "timer_seconds": 60},
      {"step_number": 6, "text": "Season with salt and white pepper. Ladle into bowls and garnish with sliced green onions. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Creamy Spinach Egg Bowl",
    "ingredients": [
      {"name": "Eggs", "quantity": 3, "unit": "large", "prep_note": ""},
      {"name": "Baby spinach", "quantity": 2, "unit": "cups", "prep_note": "Packed"},
      {"name": "Heavy cream", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Butter", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Parmesan cheese", "quantity": 2, "unit": "tbsp", "prep_note": "Grated"},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Nutmeg", "quantity": 1, "unit": "pinch", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Melt butter in a non-stick skillet over medium heat until foaming.", "timer_seconds": 60},
      {"step_number": 2, "text": "Sauté minced garlic for 30 seconds until fragrant but not browned.", "timer_seconds": 30},
      {"step_number": 3, "text": "Add spinach and toss with tongs until fully wilted, about 2 minutes.", "timer_seconds": 120},
      {"step_number": 4, "text": "Whisk eggs with heavy cream, salt, pepper, and nutmeg in a small bowl.", "timer_seconds": null},
      {"step_number": 5, "text": "Push the spinach to the sides of the pan. Pour egg mixture into the center. Gently stir with a spatula, folding the edges in as they set. Cook until just set but still creamy, about 3 minutes.", "timer_seconds": 180},
      {"step_number": 6, "text": "Remove from heat. Sprinkle with grated Parmesan and serve in a warm bowl.", "timer_seconds": null}
    ]
  },
  {
