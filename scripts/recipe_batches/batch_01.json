  {
    "title": "Spinach Chicken Milk Soup",
    "ingredients": [
      {"name": "Chicken breast", "quantity": 300, "unit": "g", "prep_note": "Diced"},
      {"name": "Baby spinach", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Whole milk", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Chicken broth", "quantity": 1, "unit": "cup", "prep_note": ""},
      {"name": "Onion", "quantity": 1, "unit": "small", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Flour", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Nutmeg", "quantity": 1, "unit": "pinch", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Melt butter in a large saucepan over medium heat. Add onion and garlic, cook for 3 minutes until softened.", "timer_seconds": 180},
      {"step_number": 2, "text": "Add diced chicken. Sauté for 5 minutes, stirring occasionally, until chicken is white on all sides.", "timer_seconds": 300},
      {"step_number": 3, "text": "Sprinkle flour over the chicken and stir constantly for 1 minute to make a roux.", "timer_seconds": 60},
      {"step_number": 4, "text": "Slowly pour in milk and broth while stirring. Bring to a gentle simmer, stirring to avoid lumps. Cook for 8 minutes.", "timer_seconds": 480},
      {"step_number": 5, "text": "Add spinach, salt, pepper, and nutmeg. Stir until spinach wilts, about 2 minutes.", "timer_seconds": 120},
      {"step_number": 6, "text": "Taste and adjust seasoning. Serve hot with crusty bread.", "timer_seconds": null}
    ]
  },
  {
