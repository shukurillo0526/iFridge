  {
    "title": "Creamy Spinach Frittata",
    "ingredients": [
      {"name": "Eggs", "quantity": 6, "unit": "large", "prep_note": ""},
      {"name": "Baby spinach", "quantity": 3, "unit": "cups", "prep_note": ""},
