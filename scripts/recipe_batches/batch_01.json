    "steps": [
      {"step_number": 1, "text": "Preheat the oven broiler to high. Heat olive oil in a 10-inch oven-safe skillet over medium heat.", "timer_seconds": 120},
      {"step_number": 2, "text": "Sauté onion for 3 minutes until translucent. Add garlic and cook 30 seconds.", "timer_seconds": 210},
      {"step_number": 3, "text": "Add spinach and stir until wilted, about 2 minutes. Spread evenly in the pan.", "timer_seconds": 120},
      {"step_number": 4, "text": "Whisk eggs, cream, salt, and pepper together. Pour over the spinach.", "timer_seconds": null},
      {"step_number": 5, "text": "Scatter feta and cherry tomato halves on top. Cook without stirring on the stovetop for 5 minutes until edges set.", "timer_seconds": 300},
      {"step_number": 6, "text": "Transfer the skillet under the broiler. Broil for 3-4 minutes until the top is puffed and golden.", "timer_seconds": 210},
      {"step_number": 7, "text": "Let cool for 2 minutes in the pan. Slice into wedges and serve.", "timer_seconds": 120}
    ]
  },
  {
