      {"step_number": 3, "text": "Add beans and 2 tbsp water. Cook for 5 minutes, mashing some beans with a fork for creaminess.", "timer_seconds": 300},
      {"step_number": 4, "text": "Season with salt and lime juice.", "timer_seconds": null},
      {"step_number": 5, "text": "Serve beans over rice, topped with avocado slices and cilantro.", "timer_seconds": null}
    ]
  },
  {
    "title": "Creamy Potato Soup",
    "ingredients": [
      {"name": "Potatoes", "quantity": 4, "unit": "large", "prep_note": "Peeled, cubed"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Chicken broth", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Heavy cream", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Chives", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"},
      {"name": "Cheddar cheese", "quantity": 0.5, "unit": "cup", "prep_note": "Shredded"}
    ],
    "steps": [
      {"step_number": 1, "text": "Melt butter in a large pot over medium heat. Sauté onion for 4 minutes until soft.", "timer_seconds": 240},
      {"step_number": 2, "text": "Add garlic, cook 30 seconds. Add cubed potatoes and broth. Bring to a boil.", "timer_seconds": 300},
      {"step_number": 3, "text": "Reduce heat and simmer for 15-20 minutes until potatoes are very tender.", "timer_seconds": 1050},
      {"step_number": 4, "text": "Mash about half the potatoes with a potato masher for a chunky texture (or blend for smooth).", "timer_seconds": null},
      {"step_number": 5, "text": "Stir in cream, salt, and pepper. Heat through for 2 minutes.", "timer_seconds": 120},
      {"step_number": 6, "text": "Serve topped with shredded cheddar and chives.", "timer_seconds": null}
    ]
  }
]
