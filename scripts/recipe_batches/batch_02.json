[
  {
    "title": "Classic Banana Bread",
    "ingredients": [
      {"name": "Ripe bananas", "quantity": 3, "unit": "large", "prep_note": "Mashed"},
      {"name": "All-purpose flour", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Sugar", "quantity": 0.75, "unit": "cup", "prep_note": ""},
      {"name": "Butter", "quantity": 0.33, "unit": "cup", "prep_note": "Melted"},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": "Beaten"},
      {"name": "Baking soda", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Vanilla extract", "quantity": 1, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to 175°C (350°F). Grease a 9x5 inch loaf pan with butter.", "timer_seconds": null},
      {"step_number": 2, "text": "Mash bananas in a large bowl until smooth. Stir in melted butter.", "timer_seconds": null},
      {"step_number": 3, "text": "Mix in sugar, beaten egg, and vanilla extract until combined.", "timer_seconds": null},
      {"step_number": 4, "text": "Add flour, baking soda, and salt. Fold gently until just combined — do not overmix.", "timer_seconds": null},
      {"step_number": 5, "text": "Pour batter into the prepared pan. Bake for 55-60 minutes until a toothpick comes out clean.", "timer_seconds": 3600},
      {"step_number": 6, "text": "Cool in pan for 10 minutes, then turn out onto a wire rack.", "timer_seconds": 600}
    ]
  },
  {
    "title": "Cheese Tomato Tart",
    "ingredients": [
      {"name": "Puff pastry sheet", "quantity": 1, "unit": "sheet", "prep_note": "Thawed"},
      {"name": "Tomatoes", "quantity": 3, "unit": "medium", "prep_note": "Sliced 5mm thick"},
      {"name": "Mozzarella", "quantity": 1, "unit": "cup", "prep_note": "Shredded"},
      {"name": "Parmesan", "quantity": 0.25, "unit": "cup", "prep_note": "Grated"},
      {"name": "Dijon mustard", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Fresh basil", "quantity": 8, "unit": "leaves", "prep_note": ""},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Preheat oven to 200°C (400°F). Line a baking sheet with parchment paper.", "timer_seconds": null},
      {"step_number": 2, "text": "Unroll puff pastry onto the parchment. Score a 1cm border around the edge with a knife.", "timer_seconds": null},
      {"step_number": 3, "text": "Spread Dijon mustard inside the border. Sprinkle mozzarella evenly.", "timer_seconds": null},
      {"step_number": 4, "text": "Arrange tomato slices in overlapping rows. Season with salt and pepper. Drizzle olive oil.", "timer_seconds": null},
      {"step_number": 5, "text": "Bake for 20-25 minutes until the pastry is golden and puffed.", "timer_seconds": 1350},
      {"step_number": 6, "text": "Remove from oven. Sprinkle Parmesan and fresh basil leaves. Slice and serve warm.", "timer_seconds": null}
    ]
  },
  {
    "title": "Classic Fried Rice",
    "ingredients": [
      {"name": "Cooked rice", "quantity": 3, "unit": "cups", "prep_note": "Day-old, cold"},
      {"name": "Eggs", "quantity": 2, "unit": "large", "prep_note": "Beaten"},
      {"name": "Soy sauce", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Sesame oil", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Frozen peas and carrots", "quantity": 0.5, "unit": "cup", "prep_note": ""},
      {"name": "Green onion", "quantity": 2, "unit": "stalks", "prep_note": "Sliced"},
      {"name": "White pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat 1 tbsp oil in a wok over high heat until smoking. Add beaten eggs, scramble quickly for 30 seconds. Remove and set aside.", "timer_seconds": 30},
      {"step_number": 2, "text": "Add remaining oil. Stir-fry garlic for 15 seconds until fragrant.", "timer_seconds": 15},
      {"step_number": 3, "text": "Add frozen peas and carrots. Stir-fry for 2 minutes.", "timer_seconds": 120},
      {"step_number": 4, "text": "Add cold rice, breaking up any clumps. Stir-fry for 3-4 minutes, pressing rice against the wok to get a slight char.", "timer_seconds": 240},
      {"step_number": 5, "text": "Add soy sauce, sesame oil, and white pepper. Toss to coat evenly. Return eggs and toss.", "timer_seconds": 60},
      {"step_number": 6, "text": "Garnish with green onions. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Scrambled Eggs on Toast",
    "ingredients": [
      {"name": "Eggs", "quantity": 3, "unit": "large", "prep_note": ""},
      {"name": "Butter", "quantity": 1.5, "unit": "tbsp", "prep_note": ""},
      {"name": "Heavy cream", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Bread", "quantity": 2, "unit": "slices", "prep_note": "Thick-cut, toasted"},
      {"name": "Chives", "quantity": 1, "unit": "tbsp", "prep_note": "Finely chopped"},
      {"name": "Salt", "quantity": 0.25, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 1, "unit": "pinch", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Crack eggs into a bowl. Add cream, salt, and pepper. Whisk vigorously until uniform.", "timer_seconds": null},
      {"step_number": 2, "text": "Melt butter in a non-stick pan over medium-low heat.", "timer_seconds": 30},
      {"step_number": 3, "text": "Pour in eggs. Let sit for 20 seconds, then gently push with a spatula from edges to center. Repeat until eggs form large, soft curds — about 3 minutes total. Remove while still slightly wet.", "timer_seconds": 180},
      {"step_number": 4, "text": "Place scrambled eggs on buttered toast. Sprinkle chives on top. Serve immediately.", "timer_seconds": null}
    ]
  },
  {
    "title": "Chicken Stir-Fry",
    "ingredients": [
      {"name": "Chicken breast", "quantity": 400, "unit": "g", "prep_note": "Sliced thin"},
      {"name": "Bell pepper", "quantity": 1, "unit": "large", "prep_note": "Sliced"},
      {"name": "Broccoli", "quantity": 1.5, "unit": "cups", "prep_note": "Florets"},
      {"name": "Soy sauce", "quantity": 3, "unit": "tbsp", "prep_note": ""},
      {"name": "Oyster sauce", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Cornstarch", "quantity": 1, "unit": "tsp", "prep_note": "Dissolved in 2 tbsp water"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Ginger", "quantity": 1, "unit": "tsp", "prep_note": "Grated"},
      {"name": "Vegetable oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Cooked rice", "quantity": 2, "unit": "cups", "prep_note": "For serving"}
    ],
    "steps": [
      {"step_number": 1, "text": "Mix soy sauce, oyster sauce, and cornstarch slurry in a small bowl. Set aside.", "timer_seconds": null},
      {"step_number": 2, "text": "Heat oil in a wok over high heat until smoking. Add chicken in a single layer. Sear for 2 minutes without moving, then stir-fry for 3 more minutes.", "timer_seconds": 300},
      {"step_number": 3, "text": "Add garlic and ginger. Stir-fry 30 seconds.", "timer_seconds": 30},
      {"step_number": 4, "text": "Add broccoli and bell pepper. Stir-fry for 3 minutes until tender-crisp.", "timer_seconds": 180},
      {"step_number": 5, "text": "Pour the sauce over everything. Toss for 1 minute until the sauce thickens and coats the chicken and vegetables.", "timer_seconds": 60},
      {"step_number": 6, "text": "Serve immediately over steamed rice.", "timer_seconds": null}
    ]
  },
  {
    "title": "Beef and Potato Stew",
    "ingredients": [
      {"name": "Beef chuck", "quantity": 500, "unit": "g", "prep_note": "Cut into 2cm cubes"},
      {"name": "Potatoes", "quantity": 3, "unit": "medium", "prep_note": "Peeled, cubed"},
      {"name": "Carrots", "quantity": 2, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Onion", "quantity": 1, "unit": "large", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Tomato paste", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Beef broth", "quantity": 3, "unit": "cups", "prep_note": ""},
      {"name": "Flour", "quantity": 2, "unit": "tbsp", "prep_note": "For dredging"},
      {"name": "Olive oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Bay leaf", "quantity": 2, "unit": "leaves", "prep_note": ""},
      {"name": "Thyme", "quantity": 1, "unit": "tsp", "prep_note": "Dried"},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.5, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Toss beef cubes in flour, salt, and pepper. Heat oil in a Dutch oven over high heat.", "timer_seconds": null},
      {"step_number": 2, "text": "Brown the beef on all sides in batches, about 3 minutes per batch. Do not crowd the pot. Remove and set aside.", "timer_seconds": 360},
      {"step_number": 3, "text": "Reduce heat to medium. Add onion and garlic, cook for 3 minutes until softened.", "timer_seconds": 180},
      {"step_number": 4, "text": "Stir in tomato paste and cook for 1 minute. Deglaze with beef broth, scraping up browned bits.", "timer_seconds": 60},
      {"step_number": 5, "text": "Return beef to the pot. Add potatoes, carrots, bay leaves, and thyme. Bring to a boil, then reduce to a low simmer.", "timer_seconds": null},
      {"step_number": 6, "text": "Cover and simmer for 45 minutes until beef is fork-tender and potatoes are soft.", "timer_seconds": 2700},
      {"step_number": 7, "text": "Remove bay leaves. Taste and adjust seasoning. Serve in deep bowls with crusty bread.", "timer_seconds": null}
    ]
  },
  {
    "title": "Lentil Soup",
    "ingredients": [
      {"name": "Red lentils", "quantity": 1, "unit": "cup", "prep_note": "Rinsed"},
      {"name": "Onion", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Carrot", "quantity": 1, "unit": "medium", "prep_note": "Diced"},
      {"name": "Celery", "quantity": 1, "unit": "stalk", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 3, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Cumin", "quantity": 1, "unit": "tsp", "prep_note": "Ground"},
      {"name": "Vegetable broth", "quantity": 4, "unit": "cups", "prep_note": ""},
      {"name": "Olive oil", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Lemon juice", "quantity": 1, "unit": "tbsp", "prep_note": "Fresh"},
      {"name": "Salt", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Black pepper", "quantity": 0.25, "unit": "tsp", "prep_note": ""}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat olive oil in a large pot over medium heat. Sauté onion, carrot, and celery for 5 minutes until softened.", "timer_seconds": 300},
      {"step_number": 2, "text": "Add garlic and cumin. Cook for 1 minute until fragrant.", "timer_seconds": 60},
      {"step_number": 3, "text": "Add lentils and broth. Bring to a boil, then reduce heat to low. Cover and simmer for 20 minutes until lentils are very soft.", "timer_seconds": 1200},
      {"step_number": 4, "text": "Use an immersion blender to partially blend (leave some texture). Add lemon juice, salt, and pepper.", "timer_seconds": null},
      {"step_number": 5, "text": "Serve hot, drizzled with extra olive oil.", "timer_seconds": null}
    ]
  },
  {
    "title": "Simple Pancakes",
    "ingredients": [
      {"name": "All-purpose flour", "quantity": 1.5, "unit": "cups", "prep_note": ""},
      {"name": "Milk", "quantity": 1.25, "unit": "cups", "prep_note": ""},
      {"name": "Egg", "quantity": 1, "unit": "large", "prep_note": ""},
      {"name": "Butter", "quantity": 2, "unit": "tbsp", "prep_note": "Melted, plus extra for pan"},
      {"name": "Sugar", "quantity": 2, "unit": "tbsp", "prep_note": ""},
      {"name": "Baking powder", "quantity": 2, "unit": "tsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Maple syrup", "quantity": 3, "unit": "tbsp", "prep_note": "For serving"}
    ],
    "steps": [
      {"step_number": 1, "text": "Whisk flour, sugar, baking powder, and salt in a large bowl.", "timer_seconds": null},
      {"step_number": 2, "text": "In a separate bowl, mix milk, egg, and melted butter.", "timer_seconds": null},
      {"step_number": 3, "text": "Pour wet ingredients into dry. Stir until just combined — lumps are OK. Rest batter 5 minutes.", "timer_seconds": 300},
      {"step_number": 4, "text": "Heat a griddle over medium heat. Brush with butter. Pour 1/4 cup batter per pancake.", "timer_seconds": null},
      {"step_number": 5, "text": "Cook until bubbles form on surface and edges look dry, about 2 minutes. Flip and cook 1 more minute.", "timer_seconds": 180},
      {"step_number": 6, "text": "Stack pancakes and serve with maple syrup and butter.", "timer_seconds": null}
    ]
  },
  {
    "title": "Bean and Rice Bowl",
    "ingredients": [
      {"name": "Cooked rice", "quantity": 2, "unit": "cups", "prep_note": ""},
      {"name": "Black beans", "quantity": 1, "unit": "can (400g)", "prep_note": "Drained and rinsed"},
      {"name": "Onion", "quantity": 0.5, "unit": "medium", "prep_note": "Diced"},
      {"name": "Garlic", "quantity": 2, "unit": "cloves", "prep_note": "Minced"},
      {"name": "Cumin", "quantity": 1, "unit": "tsp", "prep_note": ""},
      {"name": "Chili powder", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Lime juice", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Olive oil", "quantity": 1, "unit": "tbsp", "prep_note": ""},
      {"name": "Salt", "quantity": 0.5, "unit": "tsp", "prep_note": ""},
      {"name": "Avocado", "quantity": 0.5, "unit": "medium", "prep_note": "Sliced"},
      {"name": "Cilantro", "quantity": 2, "unit": "tbsp", "prep_note": "Chopped"}
    ],
    "steps": [
      {"step_number": 1, "text": "Heat olive oil in a skillet over medium heat. Sauté onion for 3 minutes.", "timer_seconds": 180},
